# ──────────────────────────────────────────────────────────────
# Recruit Wars — environment variables
# Copy to `.env.local` and fill in. The app runs in DEMO MODE with
# rich mock data when these are absent, so you can develop the UI
# before wiring up external services.
# ──────────────────────────────────────────────────────────────

# Public site config (optional overrides — see config/site.ts)
NEXT_PUBLIC_SITE_NAME="Recruit Wars"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Supabase ──────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Server-only. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── Stripe ────────────────────────────────────────────────────
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Dashboard → Developers → Webhooks (or `stripe listen` CLI)
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="Recruit Wars <noreply@recruitwars.app>"
